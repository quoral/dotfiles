{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "module": "Node16",
    "target": "ES2022",
    "moduleResolution": "Node16",
    "jsx": "react-jsx",
    "strict": true,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["src/**/*"]
}
